<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>統計儀表板</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f1f5f9}
.fade-in{animation:fadeIn .3s ease-out}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.card{background:#fff;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.tab-active{background:#2563eb;color:#fff}
.tab-inactive{background:#f1f5f9;color:#64748b;cursor:pointer}
.tab-inactive:hover{background:#e2e8f0}
.nav-btn{width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:8px;border:1px solid #e2e8f0;background:#fff;cursor:pointer;color:#64748b;transition:.15s}
.nav-btn:hover{background:#f1f5f9;color:#1e293b}
.kpi-val{font-size:1.75rem;font-weight:700;line-height:1}
</style>
</head>
<body class="min-h-screen p-4 md:p-6">

<!-- LOGIN -->
<div id="loginPanel" class="max-w-sm mx-auto mt-20 hidden">
  <div class="card p-8 text-center fade-in">
    <div class="text-3xl mb-3">📊</div>
    <h1 class="text-xl font-bold text-slate-800 mb-6">統計儀表板</h1>
    <input type="password" id="loginPass" placeholder="請輸入密碼"
      class="w-full px-4 py-3 border-2 border-slate-100 rounded-xl mb-4 focus:border-blue-400 focus:outline-none text-center"
      onkeydown="if(event.key==='Enter')doLogin()">
    <button onclick="doLogin()"
      class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl transition">登入</button>
    <p id="loginError" class="text-red-500 text-sm mt-3 hidden">密碼錯誤</p>
  </div>
  <p class="text-center text-xs text-slate-400 mt-4">使用管理員密碼登入</p>
</div>

<!-- DASHBOARD -->
<div id="mainPanel" class="max-w-7xl mx-auto hidden">

  <!-- Header -->
  <div class="flex flex-wrap justify-between items-center mb-6 fade-in">
    <div>
      <h1 class="text-2xl font-bold text-slate-800">📊 統計儀表板</h1>
      <p class="text-sm text-slate-400 mt-0.5" id="headerSubtitle">即時網站訪問統計</p>
    </div>
    <div class="flex gap-2">
      <button onclick="exportCSV()"
        class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-medium flex items-center gap-1.5 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        匯出 CSV
      </button>
      <button onclick="doLogout()"
        class="px-4 py-2 border border-slate-200 text-slate-600 rounded-lg text-sm hover:bg-slate-50 transition">登出</button>
    </div>
  </div>

  <!-- KPI Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-5 fade-in" id="kpiRow">
    <div class="card p-4"><p class="text-xs text-slate-400 font-medium mb-1.5">本日訪問</p><p class="kpi-val text-blue-600" id="kpiDayVisits">-</p></div>
    <div class="card p-4"><p class="text-xs text-slate-400 font-medium mb-1.5">不重複訪客</p><p class="kpi-val text-emerald-600" id="kpiDayUsers">-</p></div>
    <div class="card p-4"><p class="text-xs text-slate-400 font-medium mb-1.5">本週訪問</p><p class="kpi-val text-purple-600" id="kpiWeekVisits">-</p></div>
    <div class="card p-4"><p class="text-xs text-slate-400 font-medium mb-1.5">本月訪問</p><p class="kpi-val text-orange-600" id="kpiMonthVisits">-</p></div>
  </div>

  <!-- Controls: Tabs + Navigation + Filter -->
  <div class="card p-3 md:p-4 mb-5 fade-in">
    <div class="flex flex-wrap items-center gap-3">
      <!-- View Tabs -->
      <div class="flex rounded-lg overflow-hidden border border-slate-200 text-sm font-medium">
        <button class="px-4 py-2 tab-active" data-view="daily" onclick="switchView('daily')">日</button>
        <button class="px-4 py-2 tab-inactive" data-view="weekly" onclick="switchView('weekly')">週</button>
        <button class="px-4 py-2 tab-inactive" data-view="monthly" onclick="switchView('monthly')">月</button>
        <button class="px-4 py-2 tab-inactive" data-view="overview" onclick="switchView('overview')">總覽</button>
      </div>

      <!-- Date Navigation -->
      <div class="flex items-center gap-2 ml-auto md:ml-0" id="dateNav">
        <button class="nav-btn" onclick="navDate(-1)" title="上一頁">◀</button>
        <span class="text-sm font-medium text-slate-700 min-w-[140px] text-center select-none" id="dateLabel">-</span>
        <button class="nav-btn" onclick="navDate(1)" title="下一頁">▶</button>
      </div>

      <!-- Service Filter -->
      <div class="flex items-center gap-2">
        <label class="text-xs text-slate-500">服務：</label>
        <select id="serviceFilter" onchange="onFilterChange()"
          class="px-3 py-1.5 border border-slate-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-400">
          <option value="">全部</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Charts -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-4 mb-5">
    <div class="card p-4 lg:col-span-3 fade-in">
      <h3 class="font-bold text-slate-800 text-sm mb-3" id="trendTitle">趨勢圖</h3>
      <div class="h-64"><canvas id="trendChart"></canvas></div>
    </div>
    <div class="card p-4 lg:col-span-2 fade-in">
      <h3 class="font-bold text-slate-800 text-sm mb-3">各服務統計</h3>
      <div class="h-64"><canvas id="serviceChart"></canvas></div>
    </div>
  </div>

  <!-- Data Table -->
  <div class="card overflow-hidden fade-in mb-6">
    <div class="px-4 py-3 border-b border-slate-100 flex flex-wrap justify-between items-center gap-2">
      <h3 class="font-bold text-slate-800 text-sm">明細記錄</h3>
      <div class="flex gap-2">
        <input type="text" id="searchInput" oninput="filterTable()" placeholder="搜尋頁面或用戶…"
          class="px-3 py-1.5 border border-slate-200 rounded-lg text-xs w-40 focus:outline-none focus:ring-2 focus:ring-blue-400">
      </div>
    </div>
    <div class="overflow-x-auto max-h-80">
      <table class="w-full text-xs">
        <thead class="bg-slate-50 sticky top-0 text-slate-500">
          <tr>
            <th class="py-2.5 px-3 text-left font-medium cursor-pointer select-none" onclick="sortBy('time')">時間</th>
            <th class="py-2.5 px-3 text-left font-medium cursor-pointer select-none" onclick="sortBy('page')">頁面</th>
            <th class="py-2.5 px-3 text-left font-medium">用戶 ID</th>
          </tr>
        </thead>
        <tbody id="recordsTable"></tbody>
      </table>
    </div>
    <div class="px-4 py-2.5 border-t border-slate-100 text-xs text-slate-400 flex justify-between">
      <span id="tableInfo">載入中…</span>
      <span id="totalStats"></span>
    </div>
  </div>
</div>

<!-- Toast -->
<div id="toast" class="hidden fixed top-5 left-1/2 -translate-x-1/2 px-6 py-3 rounded-xl shadow-xl z-50 text-white font-bold text-sm transition-all"></div>

<script>
// ── State ──
let state = {
  view: 'daily',
  currentDate: new Date(),
  currentYear: new Date().getFullYear(),
  currentWeek: getWeekNumber(new Date()),
  currentMonth: new Date().getMonth() + 1,
  serviceFilter: '',
  allDailyStats: [],
  allRecords: [],
  sortCol: 'time',
  sortAsc: false,
  trendChart: null,
  serviceChart: null
};

function getWeekNumber(d) {
  const s = new Date(d.getFullYear(),0,1);
  return Math.ceil((((d-s)/86400000)+s.getDay()+1)/7);
}

function hkDate(d) {
  const off = d.getTime() + 8*3600000;
  const nd = new Date(off);
  return nd.getUTCFullYear()+'-'+String(nd.getUTCMonth()+1).padStart(2,'0')+'-'+String(nd.getUTCDate()).padStart(2,'0');
}

function hkDateObj(d) {
  const off = d.getTime() + 8*3600000;
  return new Date(off);
}

async function api(url) {
  const r = await fetch(url, {credentials:'include'});
  if (!r.ok) throw new Error(r.statusText);
  return r.json();
}

// ── Auth ──
async function checkAuth() {
  try {
    const d = await api('/api/stats/check');
    if (d.authenticated) { showDash(); loadDashboard(); }
    else showLogin();
  } catch(e){showLogin()}
}

function showLogin() {
  document.getElementById('loginPanel').classList.remove('hidden');
  document.getElementById('mainPanel').classList.add('hidden');
  document.getElementById('loginPass').focus();
}

function showDash() {
  document.getElementById('loginPanel').classList.add('hidden');
  document.getElementById('mainPanel').classList.remove('hidden');
}

async function doLogin() {
  const p = document.getElementById('loginPass').value;
  try {
    const r = await fetch('/api/stats/login', {
      method:'POST', credentials:'include',
      headers:{'Content-Type':'application/x-www-form-urlencoded'},
      body:'username=admin&password='+encodeURIComponent(p)
    });
    if (r.ok) { showDash(); loadDashboard(); }
    else { document.getElementById('loginError').classList.remove('hidden'); }
  } catch(e){}
}

function doLogout() {
  fetch('/api/stats/logout',{method:'POST',credentials:'include'});
  showLogin();
}

// ── Dashboard Load ──
async function loadDashboard() {
  try {
    // Load all daily stats for KPIs
    state.allDailyStats = await api('/api/statistics/daily');
    const dailies = Object.values(state.allDailyStats);
    const todayKey = hkDate(new Date());
    const today = state.allDailyStats[todayKey] || {visitCount:0,userCount:0};
    let weekV=0, monthV=0;
    const now = new Date();
    const nowHK = hkDateObj(now);
    const monthStart = nowHK.getUTCFullYear()+'-'+String(nowHK.getUTCMonth()+1).padStart(2,'0')+'-01';
    dailies.forEach(d=>{
      if (d.date) {
        if (d.date >= monthStart) monthV += d.visitCount || 0;
      }
    });
    // Simple week calc
    const weekStart = new Date(nowHK.getTime() - (nowHK.getDay()||7)*86400000 + 86400000);
    const ws = weekStart.getUTCFullYear()+'-'+String(weekStart.getUTCMonth()+1).padStart(2,'0')+'-'+String(weekStart.getUTCDate()).padStart(2,'0');
    dailies.forEach(d=>{if(d.date&&d.date>=ws)weekV+=d.visitCount||0;});

    document.getElementById('kpiDayVisits').textContent = today.visitCount||0;
    document.getElementById('kpiDayUsers').textContent = today.userCount||0;
    document.getElementById('kpiWeekVisits').textContent = weekV;
    document.getElementById('kpiMonthVisits').textContent = monthV;

    // Load service filter
    const svcRes = await api('/api/statistics/service-stats');
    const sel = document.getElementById('serviceFilter');
    svcRes.forEach(s=>{
      if (!s.page) return;
      const o = document.createElement('option');
      o.value = s.page; o.textContent = s.page;
      sel.appendChild(o);
    });

    // Load initial view
    loadView();
  } catch(e){console.error(e)}
}

// ── View Switching ──
function switchView(view) {
  state.view = view;
  document.querySelectorAll('[data-view]').forEach(b=>{
    b.className = b.dataset.view===view ? 'px-4 py-2 tab-active' : 'px-4 py-2 tab-inactive';
  });
  loadView();
}

function loadView() {
  switch(state.view) {
    case 'daily': loadDayView(hkDate(state.currentDate)); break;
    case 'weekly': loadWeekView(state.currentYear, state.currentWeek); break;
    case 'monthly': loadMonthView(state.currentYear, state.currentMonth); break;
    case 'overview': loadOverview(); break;
  }
}

function navDate(dir) {
  switch(state.view) {
    case 'daily': {
      const d = new Date(state.currentDate.getTime() + dir*86400000);
      state.currentDate = d;
      loadDayView(hkDate(d));
      break;
    }
    case 'weekly': {
      state.currentWeek += dir;
      if (state.currentWeek<1){state.currentWeek=52;state.currentYear--}
      if (state.currentWeek>52){state.currentWeek=1;state.currentYear++}
      loadWeekView(state.currentYear, state.currentWeek);
      break;
    }
    case 'monthly': {
      state.currentMonth += dir;
      if (state.currentMonth<1){state.currentMonth=12;state.currentYear--}
      if (state.currentMonth>12){state.currentMonth=1;state.currentYear++}
      loadMonthView(state.currentYear, state.currentMonth);
      break;
    }
  }
}

function onFilterChange() {
  state.serviceFilter = document.getElementById('serviceFilter').value;
  loadView();
}

// ── Daily View ──
async function loadDayView(dateStr) {
  document.getElementById('dateLabel').textContent = dateStr;
  document.getElementById('trendTitle').textContent = dateStr + ' 每小時分布';
  try {
    const data = await api('/api/statistics/day-detail?date='+dateStr+'&page='+state.serviceFilter);
    renderTrendChartHourly(data.hourlyDistribution||[]);
    renderServiceChart(data.pages||[]);
    renderKPIDetail(data.totalVisits, data.uniqueUsers);
    // Load records
    const records = await api('/api/statistics/statistics');
    const filter = state.serviceFilter;
    const filtered = filter ? records.filter(r=>r.pagePath===filter) : records;
    renderTable(filtered);
    document.getElementById('totalStats').textContent = '共 ' + filtered.length + ' 筆';
  } catch(e){console.error(e)}
}

// ── Weekly View ──
async function loadWeekView(year, week) {
  document.getElementById('dateLabel').textContent = year + ' 第 ' + week + ' 週';
  document.getElementById('trendTitle').textContent = '本週每日趨勢';
  try {
    const data = await api('/api/statistics/week-detail?year='+year+'&week='+week+'&page='+state.serviceFilter);
    renderTrendChartDaily(data.dailyTrend||[]);
    renderServiceChart(data.pages||[]);
    renderKPIDetail(data.totalVisits, data.uniqueUsers);
    const records = await api('/api/statistics/statistics');
    renderTable(records);
    document.getElementById('totalStats').textContent = '本週 ' + (data.totalVisits||0) + ' 次訪問';
  } catch(e){console.error(e)}
}

// ── Monthly View ──
async function loadMonthView(year, month) {
  document.getElementById('dateLabel').textContent = year + ' 年 ' + month + ' 月';
  document.getElementById('trendTitle').textContent = '本月每日趨勢';
  try {
    const data = await api('/api/statistics/month-detail?year='+year+'&month='+month+'&page='+state.serviceFilter);
    renderTrendChartDaily(data.dailyTrend||[]);
    renderServiceChart(data.pages||[]);
    renderKPIDetail(data.totalVisits, data.uniqueUsers);
    const records = await api('/api/statistics/statistics');
    renderTable(records);
    document.getElementById('totalStats').textContent = '本月 ' + (data.totalVisits||0) + ' 次訪問';
  } catch(e){console.error(e)}
}

// ── Overview ──
async function loadOverview() {
  document.getElementById('dateLabel').textContent = '總覽';
  document.getElementById('trendTitle').textContent = '每日趨勢（近30天）';
  try {
    const [dailyData, svcData, records] = await Promise.all([
      api('/api/statistics/daily'),
      api('/api/statistics/service-stats'),
      api('/api/statistics/statistics')
    ]);
    const dailies = Object.values(dailyData).sort((a,b)=>(a.date||'').localeCompare(b.date||''));
    const last30 = dailies.slice(-30);
    renderTrendChartDaily(last30);
    renderServiceChart(svcData);
    renderKPIDetail(records.length, new Set(records.map(r=>r.userId)).size);
    const filter = state.serviceFilter;
    const filtered = filter ? records.filter(r=>r.pagePath===filter) : records;
    renderTable(filtered);
    document.getElementById('totalStats').textContent = '總計 ' + records.length + ' 次訪問';
  } catch(e){console.error(e)}
}

function renderKPIDetail(visits, users) {
  document.getElementById('kpiDayVisits').textContent = visits;
  document.getElementById('kpiDayUsers').textContent = users;
}

// ── Charts ──
function renderTrendChartHourly(hourly) {
  const labels = Array.from({length:24},(_,i)=>i+'時');
  const data = Array(24).fill(0);
  (hourly||[]).forEach(h=>{if(h.hour>=0&&h.hour<24)data[h.hour]=h.visits});
  renderChart('trendChart', 'bar', labels, [{label:'訪問次數',data,backgroundColor:'#3b82f6'}]);
}

function renderTrendChartDaily(daily) {
  if (!daily||!daily.length) { renderChart('trendChart','line',[],[]); return; }
  const labels = daily.map(d=>d.date||d.date||'');
  const visits = daily.map(d=>d.visits||0);
  const users = daily.map(d=>d.uniqueUsers||0);
  renderChart('trendChart', 'line', labels, [
    {label:'訪問次數',data:visits,borderColor:'#3b82f6',backgroundColor:'rgba(59,130,246,.1)',tension:.3,fill:true},
    {label:'不重複用戶',data:users,borderColor:'#10b981',backgroundColor:'rgba(16,185,129,.1)',tension:.3,fill:true}
  ]);
}

function renderServiceChart(data) {
  if (!data||!data.length) return;
  const top = data.slice(0,10);
  const labels = top.map(d=>d.page||'/');
  const visits = top.map(d=>d.visits||0);
  const colors = ['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#ec4899','#06b6d4','#84cc16','#f97316','#6366f1'];
  renderChart('serviceChart', 'bar', labels, [{
    label:'訪問次數',data:visits,backgroundColor:colors.slice(0,top.length)
  }], {indexAxis:'y',plugins:{legend:{display:false}}});
}

function renderChart(canvasId, type, labels, datasets, extraOpts) {
  const ctx = document.getElementById(canvasId).getContext('2d');
  if (state.trendChart && canvasId==='trendChart') state.trendChart.destroy();
  if (state.serviceChart && canvasId==='serviceChart') state.serviceChart.destroy();
  const chart = new Chart(ctx, {
    type, data:{labels,datasets},
    options:Object.assign({
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{position:'top',labels:{boxWidth:12,font:{size:11}}}},
      scales:{y:{beginAtZero:true}}
    }, extraOpts||{})
  });
  if (canvasId==='trendChart') state.trendChart = chart;
  else state.serviceChart = chart;
}

// ── Table ──
function renderTable(records) {
  state.allRecords = records;
  filterTable();
}

function filterTable() {
  const q = (document.getElementById('searchInput').value||'').toLowerCase();
  const filtered = state.allRecords.filter(r=>
    (r.pagePath||'').toLowerCase().includes(q)||(r.userId||'').toLowerCase().includes(q)
  );
  const sorted = [...filtered].sort((a,b)=>{
    let va=a[state.sortCol], vb=b[state.sortCol];
    if (state.sortCol==='time'){va=new Date(va);vb=new Date(vb)}
    return state.sortAsc ? (va>vb?1:-1) : (va<vb?1:-1);
  });
  const tbody = document.getElementById('recordsTable');
  tbody.innerHTML = sorted.slice(0,200).map(r=>
    '<tr class="border-b border-slate-50 hover:bg-slate-50">'+
    '<td class="py-2 px-3 text-slate-600 whitespace-nowrap">'+((r.time||'').replace('T',' ').slice(0,19)||'-')+'</td>'+
    '<td class="py-2 px-3 text-slate-800">'+(r.pagePath||'/')+'</td>'+
    '<td class="py-2 px-3 text-slate-400 font-mono text-[10px]" title="'+(r.userId||'')+'">'+(r.userId||'').slice(0,8)+'…</td>'+
    '</tr>'
  ).join('');
  document.getElementById('tableInfo').textContent = '顯示 ' + Math.min(200,sorted.length) + ' / ' + sorted.length + ' 筆';
}

function sortBy(col) {
  if (state.sortCol===col) state.sortAsc=!state.sortAsc;
  else {state.sortCol=col;state.sortAsc=false}
  filterTable();
}

function exportCSV() {
  const records = state.allRecords;
  if (!records.length) return;
  let csv = '時間,頁面,用戶ID\n';
  csv += records.map(r=>r.time+','+(r.pagePath||'/')+','+r.userId).join('\n');
  const blob = new Blob(['\ufeff'+csv],{type:'text/csv;charset=utf-8'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'statistics-'+hkDate(new Date())+'.csv';
  a.click();
  showToast('CSV 已下載');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'fixed top-5 left-1/2 -translate-x-1/2 px-6 py-3 rounded-xl shadow-xl z-50 text-white font-bold text-sm bg-emerald-600';
  t.classList.remove('hidden');
  setTimeout(()=>{t.classList.add('hidden')},2000);
}

checkAuth();
</script>
</body>
</html>
