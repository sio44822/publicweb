<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>訪問統計</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="bg-slate-100 min-h-screen py-8">
    <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-2xl font-bold text-slate-800 mb-6">訪問統計</h1>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <div class="bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-xl p-5 text-white shadow-lg">
                <div class="text-emerald-100 text-sm font-medium mb-1">今日訪客</div>
                <div class="text-4xl font-bold" id="todayUsers">-</div>
            </div>
            <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl p-5 text-white shadow-lg">
                <div class="text-blue-100 text-sm font-medium mb-1">今日訪問次數</div>
                <div class="text-4xl font-bold" id="todayVisits">-</div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 mb-6">
            <div class="px-5 py-4 border-b border-slate-100">
                <h2 class="font-semibold text-slate-700">每日統計</h2>
            </div>
            <div class="p-4">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-slate-500 border-b border-slate-100">
                            <th class="text-left py-2 font-medium">日期</th>
                            <th class="text-right py-2 font-medium">訪客數</th>
                            <th class="text-right py-2 font-medium">訪問次數</th>
                        </tr>
                    </thead>
                    <tbody id="dailyTable"></tbody>
                </table>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200">
            <div class="px-5 py-4 border-b border-slate-100 flex flex-col md:flex-row md:justify-between md:items-center gap-3">
                <div class="flex items-center gap-3">
                    <h2 class="font-semibold text-slate-700">訪問記錄</h2>
                    <span class="text-xs text-slate-400" id="totalRecords"></span>
                </div>
                <div class="flex flex-wrap gap-2">
                    <input type="date" id="filterDate" class="px-3 py-1.5 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <input type="text" id="filterUser" placeholder="搜尋使用者ID" class="px-3 py-1.5 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-40">
                    <button onclick="applyFilters()" class="px-3 py-1.5 bg-blue-600 text-white rounded-lg text-sm hover:bg-blue-700">篩選</button>
                    <button onclick="clearFilters()" class="px-3 py-1.5 bg-slate-100 text-slate-600 rounded-lg text-sm hover:bg-slate-200">清除</button>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-slate-500 border-b border-slate-100 bg-slate-50">
                            <th class="text-left py-3 px-4 font-medium">時間</th>
                            <th class="text-left py-3 px-4 font-medium">使用者ID</th>
                        </tr>
                    </thead>
                    <tbody id="recordsTable"></tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        let allRecords = [];

        async function loadData() {
            const [todayRes, dailyRes, recordsRes] = await Promise.all([
                fetch('/api/statistics/today'),
                fetch('/api/statistics/daily'),
                fetch('/api/statistics')
            ]);

            const today = await todayRes.json();
            const daily = await dailyRes.json();
            allRecords = await recordsRes.json();

            document.getElementById('todayUsers').textContent = today.userCount || 0;
            document.getElementById('todayVisits').textContent = today.visitCount || 0;
            document.getElementById('totalRecords').textContent = `共 ${allRecords.length} 筆`;

            const dailyRows = Object.entries(daily).sort((a, b) => b[0].localeCompare(a[0]));
            document.getElementById('dailyTable').innerHTML = dailyRows.map(([date, data]) => `
                <tr class="border-b border-slate-50 hover:bg-slate-50">
                    <td class="py-2 text-slate-700">${date}</td>
                    <td class="py-2 text-right text-slate-600">${data.userCount}</td>
                    <td class="py-2 text-right text-slate-600">${data.visitCount}</td>
                </tr>
            `).join('');

            renderRecords(allRecords);
        }

        function renderRecords(records) {
            document.getElementById('totalRecords').textContent = `共 ${records.length} 筆`;
            document.getElementById('recordsTable').innerHTML = records.map(r => `
                <tr class="border-b border-slate-50 hover:bg-slate-50 fade-in">
                    <td class="py-2 px-4 text-slate-600 whitespace-nowrap">${r.time.replace('T', ' ').substring(0, 19)}</td>
                    <td class="py-2 px-4 text-slate-800 font-mono text-xs" title="${r.userId}">${r.userId}</td>
                </tr>
            `).join('');
        }

        function applyFilters() {
            const filterDate = document.getElementById('filterDate').value;
            const filterUser = document.getElementById('filterUser').value.toLowerCase();

            let filtered = allRecords;

            if (filterDate) {
                filtered = filtered.filter(r => r.time.startsWith(filterDate));
            }

            if (filterUser) {
                filtered = filtered.filter(r => r.userId.toLowerCase().includes(filterUser));
            }

            renderRecords(filtered);
        }

        function clearFilters() {
            document.getElementById('filterDate').value = '';
            document.getElementById('filterUser').value = '';
            renderRecords(allRecords);
        }

        loadData();
    </script>
</body>
</html>