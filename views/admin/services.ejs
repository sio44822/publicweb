<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>服務管理</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .fade-in { animation: fadeIn 0.3s ease-out forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .editable:hover { background: #f3f4f6; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen py-6 px-4">

    <div id="loginPanel" class="max-w-sm mx-auto mt-16">
        <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
            <h1 class="text-xl font-bold text-gray-800 mb-4">管理員登入</h1>
            <input type="password" id="adminPass" class="w-full px-4 py-3 bg-gray-50 border-2 border-gray-100 rounded-xl mb-4" placeholder="請輸入管理密碼">
            <button onclick="doLogin()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl">登入</button>
            <p id="loginError" class="text-red-500 text-sm mt-3 hidden"></p>
        </div>
    </div>

    <div id="mainPanel" class="max-w-3xl mx-auto <%= isAdmin ? '' : 'hidden' %>">
        <header class="mb-6 fade-in">
            <h1 class="text-2xl font-bold text-gray-800">服務管理</h1>
        </header>

        <div class="grid grid-cols-2 gap-3 mb-6 fade-in">
            <a href="/mgmt/courses" class="bg-white rounded-xl p-4 border border-gray-100 shadow-sm hover:shadow-md transition-all">
                <div class="flex items-center gap-3">
                    <span class="text-2xl">📚</span>
                    <div>
                        <p class="font-bold text-gray-800">課程管理</p>
                        <p class="text-xs text-gray-400">預約課程與名額</p>
                    </div>
                </div>
            </a>
            <a href="/statistics" class="bg-white rounded-xl p-4 border border-gray-100 shadow-sm hover:shadow-md transition-all">
                <div class="flex items-center gap-3">
                    <span class="text-2xl">📊</span>
                    <div>
                        <p class="font-bold text-gray-800">訪問統計</p>
                        <p class="text-xs text-gray-400">流量分析儀表板</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="bg-white rounded-xl border border-gray-100 p-4 mb-4 flex items-center justify-between fade-in">
            <div class="flex items-center gap-4">
                <a href="/services" class="text-gray-500 hover:text-gray-700 text-sm">← 返回服務頁面</a>
            </div>
            <button onclick="doLogout()" class="text-gray-400 hover:text-gray-600 text-sm">登出</button>
        </div>

        <div class="bg-white rounded-xl border border-gray-100 overflow-hidden fade-in">
            <div class="px-4 py-3 bg-gray-50 border-b border-gray-100 flex items-center justify-between">
                <span class="font-bold text-gray-700">服務列表</span>
                <span class="text-xs text-gray-400">顯示 = 任何服務設為顯示則導航列會顯示全部服務 | 隱藏 = 該服務不顯示在導航列</span>
            </div>
            <div id="servicesList"></div>
        </div>
    </div>

    <script>
        let servicesData = <%- JSON.stringify(services) %>;
        const isAdmin = <%- isAdmin %>;

        function doLogin() {
            const pass = document.getElementById('adminPass').value;
            fetch('/api/services/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ password: pass }) })
                .then(res => {
                    if (res.ok) {
                        document.getElementById('loginPanel').classList.add('hidden');
                        document.getElementById('mainPanel').classList.remove('hidden');
                        render();
                    } else {
                        document.getElementById('loginError').textContent = '密碼錯誤';
                        document.getElementById('loginError').classList.remove('hidden');
                    }
                });
        }

        async function checkAuth() {
            try {
                const res = await fetch('/api/services/login', { method: 'GET' });
                if (res.ok) {
                    document.getElementById('loginPanel').classList.add('hidden');
                    document.getElementById('mainPanel').classList.remove('hidden');
                    render();
                }
            } catch (e) {}
        }

        function doLogout() {
            fetch('/api/services/logout', { method: 'POST' });
            document.getElementById('loginPanel').classList.remove('hidden');
            document.getElementById('mainPanel').classList.add('hidden');
            document.getElementById('adminPass').value = '';
        }

        function render() {
            const list = document.getElementById('servicesList');
            list.innerHTML = '';
            const sorted = [...servicesData].sort((a, b) => a.order - b.order);
            sorted.forEach((svc, i) => {
                const row = document.createElement('div');
                row.className = 'flex items-center gap-3 px-4 py-3 border-b border-gray-50 hover:bg-gray-50 fade-in';
                row.style.animationDelay = `${i * 40}ms`;
                row.innerHTML = `
                    <button onclick="moveOrder('${svc.id}', -1)" class="p-1 text-gray-400 hover:text-gray-600 ${i === 0 ? 'opacity-30 cursor-not-allowed' : ''}">↑</button>
                    <button onclick="moveOrder('${svc.id}', 1)" class="p-1 text-gray-400 hover:text-gray-600 ${i === sorted.length - 1 ? 'opacity-30 cursor-not-allowed' : ''}">↓</button>
                    <span class="text-xl">${svc.icon || '📁'}</span>
                    <input type="text" value="${svc.name}" onchange="quickEdit('${svc.id}', 'name', this.value)" 
                        class="flex-1 px-2 py-1 bg-transparent border-none font-medium text-gray-800 focus:outline-none focus:bg-white focus:ring-2 focus:ring-blue-500 rounded editable">
                    <input type="text" value="${svc.description || ''}" onchange="quickEdit('${svc.id}', 'description', this.value)" 
                        placeholder="說明" class="flex-1 px-2 py-1 bg-transparent border-none text-sm text-gray-400 focus:outline-none focus:bg-white focus:ring-2 focus:ring-blue-500 rounded">
                    <button onclick="toggleShowInNav('${svc.id}')" class="px-2 py-1 rounded-full text-xs font-bold ${svc.showInNav ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-400'}" title="是否在導航列顯示">
                        ${svc.showInNav ? '顯示' : '隱藏'}
                    </button>
                    <button onclick="toggleEnabled('${svc.id}')" class="px-3 py-1 rounded-full text-xs font-bold ${svc.enabled ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-400'}">
                        ${svc.enabled ? '啟用' : '停用'}
                    </button>
                    ${svc.url ? `<a href="${svc.url}" target="_blank" class="text-blue-500 hover:text-blue-600 text-sm" title="開啟服務">↗</a>` : ''}
                `;
                list.appendChild(row);
            });
        }

        async function moveOrder(id, delta) {
            const sorted = [...servicesData].sort((a, b) => a.order - b.order);
            const idx = sorted.findIndex(s => s.id === id);
            if (idx === -1 || (delta < 0 && idx === 0) || (delta > 0 && idx === sorted.length - 1)) return;
            const newOrder = sorted[idx].order + delta;
            const swapIdx = sorted.findIndex(s => s.order === newOrder);
            if (swapIdx !== -1) sorted[swapIdx].order = sorted[idx].order;
            sorted[idx].order = newOrder;
            servicesData = sorted;
            await saveData();
        }

        async function toggleEnabled(id) {
            const svc = servicesData.find(s => s.id === id);
            if (!svc) return;
            svc.enabled = !svc.enabled;
            await saveData();
        }

        async function toggleShowInNav(id) {
            const svc = servicesData.find(s => s.id === id);
            if (!svc) return;
            svc.showInNav = !svc.showInNav;
            await saveData();
        }

        async function quickEdit(id, field, value) {
            const svc = servicesData.find(s => s.id === id);
            if (!svc) return;
            svc[field] = value;
            await saveData();
        }

        async function saveData() {
            try {
                await fetch('/api/services/update', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ services: servicesData }) });
                render();
            } catch (err) { alert('儲存失敗'); }
        }

        if (isAdmin) {
            document.getElementById('loginPanel').classList.add('hidden');
            document.getElementById('mainPanel').classList.remove('hidden');
        }
        checkAuth();
    </script>
</body>
</html>